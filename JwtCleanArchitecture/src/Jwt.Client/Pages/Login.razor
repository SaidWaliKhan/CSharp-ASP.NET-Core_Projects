@page "/login"
@using Jwt.Client.Models
@using Jwt.Client.Services
@inject ApiAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="auth-card">
    <div class="jwt-strip" aria-hidden="true">
        <span class="jwt-seg jwt-seg--header"></span>
        <span class="jwt-dot">.</span>
        <span class="jwt-seg jwt-seg--payload"></span>
        <span class="jwt-dot">.</span>
        <span class="jwt-seg jwt-seg--signature"></span>
    </div>
    <p class="jwt-caption">header . payload . signature</p>

    <p class="auth-eyebrow">POST /api/auth/login</p>
    <h1 class="auth-title">Welcome back</h1>
    <p class="auth-subtitle">Sign in to fetch a fresh access token.</p>

    <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="field">
            <label for="email">Email</label>
            <InputText id="email" @bind-Value="_model.Email" placeholder="you@example.com" />
        </div>

        <div class="field">
            <label for="password">Password</label>
            <InputText id="password" type="password" @bind-Value="_model.Password" placeholder="••••••••" />
        </div>

        <button type="submit" class="auth-submit" disabled="@_isLoading">
            @(_isLoading ? "Signing in..." : "Sign in")
        </button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(_errorMessage))
    {
        <div class="auth-error">@_errorMessage</div>
    }

    <p class="auth-footer">No account? <a href="/register">Create one</a></p>
</div>

@code {
    private readonly LoginModel _model = new();
    private bool _isLoading;
    private string? _errorMessage;

    private async Task HandleLoginAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        var result = await AuthService.LoginAsync(_model);

        _isLoading = false;

        if (result.Success)
        {
            Navigation.NavigateTo("/profile", forceLoad: true);
        }
        else
        {
            _errorMessage = result.Message;
        }
    }
}